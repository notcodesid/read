{
  "expo": {
    "name": "Read",
    "slug": "read",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "scheme": "read",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.notcodesid.read",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocalNetworkUsageDescription": "Read connects to your Mac on the local network to load updates while developing.",
        "BonjourServices": [
          "_expo._tcp"
        ]
      }
    },
    "android": {
      "package": "com.notcodesid.read",
      "adaptiveIcon": {
        "backgroundColor": "#faf8f5",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "splash": {
      "image": "./assets/images/app-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#faf8f5"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#faf8f5",
          "image": "./assets/images/app-logo.png",
          "resizeMode": "contain",
          "imageWidth": 120,
          "dark": {
            "backgroundColor": "#141312"
          }
        }
      ],
      "expo-sharing",
      [
        "expo-notifications",
        {
          "defaultChannel": "reading-reminders"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "19efea75-600d-4dab-a9e2-f076d40ad946"
      }
    },
    "owner": "notcodesid-2"
  }
}
